# Server Configuration
PORT=3000

# Seven.io SMS API Key (Required for sending OTPs)
SEVEN_API_KEY="your_seven_api_key_here"

# HMAC Secret for hashing phone numbers (Required to prevent duplicates securely)
# Generate a strong random string for this in production
PHONE_HMAC_SECRET="your_secure_random_string_here"

# Cloudflare Turnstile CAPTCHA Keys
# You can get these for free at https://dash.cloudflare.com/?to=/:account/turnstile
# The defaults below are Cloudflare's official testing keys which will always pass
TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# Bunny Edge Database (libSQL)
# For local dev, leave these blank and it will use a local file `temperaturcrowd.db`.
# For production, set to your libSQL URL (e.g. libsql://your-db.bunny.net)
# DATABASE_URL=""
# DATABASE_AUTH_TOKEN=""
